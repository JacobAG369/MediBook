# ===========================
# MediBook - Variables de Entorno
# ===========================
# Copia este archivo como .env y reemplaza los valores.
#   cp .env.example .env

# --- Base de Datos ---
# Para PostgreSQL (recomendado en producción):
DATABASE_URL=postgresql://usuario:password@localhost:5432/medibook_db

# --- Seguridad ---
# Clave secreta para firmar tokens JWT (GENERAR UNA SEGURA en producción)
# Usar: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=genera-una-clave-aleatoria-segura-de-al-menos-64-caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Aplicación ---
# DEBUG=true

# --- CORS ---
# Lista separada por comas de orígenes HTTP permitidos.
# En producción reemplaza con tu dominio real.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
